DJANGO_SECRET_KEY=unsafe-development-secret-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

MYSQL_DATABASE=mongle
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=mongle
MYSQL_PASSWORD=mongle_password
MYSQL_ROOT_PASSWORD=root_password

# Gmail SMTP for email verification.
# Use a Google App Password here, not your normal Gmail password.
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-gmail@example.com
EMAIL_HOST_PASSWORD=your-google-app-password
DEFAULT_FROM_EMAIL=your-gmail@example.com

DATABASE_URL=mysql://mongle:mongle_password@db:3306/mongle
