# ────────────────────────────────────────
# Django
# ────────────────────────────────────────
DJANGO_SECRET_KEY=unsafe-development-secret-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ────────────────────────────────────────
# MySQL (Docker)
# MYSQL_PASSWORD 와 DATABASE_URL 의 비밀번호는 반드시 동일해야 합니다.
# ────────────────────────────────────────
MYSQL_DATABASE=mongle_village
MYSQL_USER=mongle
MYSQL_PASSWORD=mongle_password
MYSQL_ROOT_PASSWORD=root_password
DATABASE_URL=mysql://mongle:mongle_password@db:3306/mongle_village

# ────────────────────────────────────────
# Redis
# ────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ────────────────────────────────────────
# Gmail SMTP
# Google 계정 → 앱 비밀번호 생성 후 입력 (일반 비밀번호 사용 불가)
# ────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-gmail@example.com
EMAIL_HOST_PASSWORD=your-google-app-password
DEFAULT_FROM_EMAIL=your-gmail@example.com

# ────────────────────────────────────────
# mongle-ai 연동
# MONGLE_AI_API_KEY 는 mongle-ai 의 MONGLE_API_KEY 와 동일값이어야 합니다.
# ────────────────────────────────────────
MONGLE_AI_API_BASE=http://127.0.0.1:8010
MONGLE_AI_API_KEY=replace-with-shared-secret
MONGLE_AI_TIMEOUT_SECONDS=30

# ────────────────────────────────────────
# AWS S3 (presigned URL 발급용)
# ────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
# 모든 런타임 S3 객체의 공통 네임스페이스(AI 워커와 동일). IAM 정책 mongle-village/* 와 일치.
AWS_S3_PREFIX=mongle-village
AWS_S3_REGION=ap-northeast-2
AWS_S3_PRESIGNED_URL_EXPIRY=600

# ────────────────────────────────────────
# 시드 캐릭터/피드 이미지 (seed_dev) — 유저별로 다른 이미지
# 비워두면 로컬 static(http://localhost:8000/static/seed/<파일명>)을 사용.
# S3/CloudFront 에 직접 올린 이미지를 쓰려면 전체 URL 을 지정. 재시드 시 갱신됨.
# 예) SEED_DEMO_IMAGE_URL=https://<bucket>.s3.ap-northeast-2.amazonaws.com/mongle-village/seed/demo-character.png
# ────────────────────────────────────────
SEED_DEMO_IMAGE_URL=
SEED_ADMIN_IMAGE_URL=

# ────────────────────────────────────────
# AI 서비스 (내부 연동, 미사용 시 빈값)
# ────────────────────────────────────────
AI_SERVICE_URL=
AI_SERVICE_TOKEN=
